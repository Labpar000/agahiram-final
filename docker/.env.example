# Database
POSTGRES_USER=agahiram
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agahiram
DATABASE_URL=postgresql://agahiram:change_me_in_production@localhost:5432/agahiram?schema=public

# Redis
REDIS_URL=redis://localhost:6379
# BullMQ reads host/port/password separately (not REDIS_URL).
REDIS_HOST=redis
REDIS_PORT=6379

# MeiliSearch
MEILI_MASTER_KEY=change_me_in_production
MEILI_HOST=http://localhost:7700

# JWT
JWT_SECRET=change_me_to_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Admin allowlist (comma-separated phone numbers; required in production)
ADMIN_PHONES=09120000000,09127477990,09132609737

# Kavenegar SMS (optional)
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_DEV_MODE=true

# sms.ir SMS — OTP via verify template (service line)
SMS_IR_API_KEY=
SMS_IR_PATTERN_CODE=
SMS_IR_TEMPLATE_ID=307289
SMS_IR_PARAM_NAME=Code
SMS_IR_LINE_NUMBER=
SMS_IR_OTP_TEXT=کد آگهیرام: {code}\n\n{webOtp}\nلغو۱۱
# Web OTP autofill — must match site origin (see packages/shared/src/web-otp.ts)
WEB_OTP_DOMAIN=
SMS_IR_WEB_OTP_PARAM_NAME=WebOtp
# Force provider: smsir | kavenegar | dev
SMS_PROVIDER=smsir

# Object Storage (self-hosted MinIO)
MINIO_ROOT_USER=agahiram
MINIO_ROOT_PASSWORD=change_me_in_production
# Internal endpoint used by api/worker for head/get/put/delete (docker network).
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Public host for legacy signed reads. Browser uploads use the API proxy
# (PUT /api/v1/media/upload), not presigned MinIO URLs. /storage is still
# proxied via Caddy for direct object access when needed.
MINIO_PUBLIC_HOST=alooche.com
MINIO_PUBLIC_PORT=443
MINIO_PUBLIC_USE_SSL=true
MINIO_PUBLIC_PATH_PREFIX=/storage
MINIO_BUCKET=agahiram
MINIO_ACCESS_KEY=agahiram
MINIO_SECRET_KEY=change_me_in_production
MINIO_CORS_ORIGIN=https://alooche.com

# ZarinPal
ZARINPAL_MERCHANT_ID=your_merchant_id
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=https://alooche.com/payment/callback

# Map.ir Maps (geocoding + search on server)
MAPIR_API_KEY=your_mapir_api_key
NEXT_PUBLIC_MAPIR_API_KEY=your_mapir_api_key

# App URLs
CORS_ORIGIN=https://alooche.com
FRONTEND_URL=https://alooche.com
NEXT_PUBLIC_API_URL=https://alooche.com/api/v1
NEXT_PUBLIC_WS_URL=wss://alooche.com
NEXT_PUBLIC_APP_URL=https://alooche.com
NEXT_PUBLIC_SOCKET_URL=https://alooche.com
ADMIN_URL=https://alooche.com/admin
API_PORT=4000
TZ=Asia/Tehran
WEB_PORT=5173
ADMIN_PORT=3001

# LiveKit (Phase 3 + 1:1 video calls)
# LIVEKIT_KEYS in compose must be "key: secret" (space after colon)
LIVEKIT_API_KEY=agahiram_lk
LIVEKIT_API_SECRET=generate_with_openssl_rand_hex_32
LIVEKIT_URL=wss://alooche.com/livekit
LIVEKIT_INTERNAL_URL=http://livekit:7880
# Public IP of the VPS (auto-detected by configure-voice-video.sh if empty)
LIVEKIT_NODE_IP=
# LiveKit → API webhook (docker internal URL; override only if API is not on compose network)
LIVEKIT_WEBHOOK_URL=http://api:4000/api/v1/livekit/webhook

# Web Push — generate: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@alooche.com

# Domain (production)
DOMAIN=alooche.com
ACME_EMAIL=admin@alooche.com

# Container images (GHCR pull-mode deploy)
IMAGE_REGISTRY=ghcr.io/labpar000/agahiram
IMAGE_TAG=latest
