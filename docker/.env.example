# Database
POSTGRES_USER=agahiram
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agahiram
DATABASE_URL=postgresql://agahiram:change_me_in_production@localhost:5432/agahiram?schema=public

# Redis
REDIS_URL=redis://localhost:6379
# BullMQ reads host/port/password separately (not REDIS_URL).
REDIS_HOST=redis
REDIS_PORT=6379

# MeiliSearch
MEILI_MASTER_KEY=change_me_in_production
MEILI_HOST=http://localhost:7700

# JWT
JWT_SECRET=change_me_to_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Kavenegar SMS
KAVENEGAR_API_KEY=your_kavenegar_api_key
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_DEV_MODE=true

# Object Storage (self-hosted MinIO, S3-compatible)
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the MinIO admin creds AND are reused
# as the S3 access/secret keys below.
MINIO_ROOT_USER=agahiram
MINIO_ROOT_PASSWORD=change_me_in_production
# Internal endpoint used by api/worker for head/get/put/delete (fast, in-network).
S3_ENDPOINT=http://minio:9000
# Public endpoint used ONLY to sign browser upload URLs (must be reachable by the
# browser; served via Caddy at s3.<DOMAIN>).
S3_PUBLIC_ENDPOINT=https://s3.alooche.com
# Public base URL the worker writes into the DB (path-style; api re-proxies reads).
S3_PUBLIC_URL=https://s3.alooche.com/agahiram
S3_ACCESS_KEY=agahiram
S3_SECRET_KEY=change_me_in_production
S3_BUCKET=agahiram
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# MinIO does not support the S3 PutBucketCors API; CORS is set on the MinIO
# container via MINIO_API_CORS_ALLOW_ORIGIN instead, so skip the startup call.
S3_CONFIGURE_CORS=false

# ZarinPal
ZARINPAL_MERCHANT_ID=your_merchant_id
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=https://alooche.com/payment/callback

# Neshan Maps
NESHAN_API_KEY=your_neshan_api_key

# App URLs
CORS_ORIGIN=https://alooche.com
FRONTEND_URL=https://alooche.com
NEXT_PUBLIC_API_URL=https://alooche.com/api/v1
NEXT_PUBLIC_WS_URL=wss://alooche.com
NEXT_PUBLIC_APP_URL=https://alooche.com
NEXT_PUBLIC_SOCKET_URL=https://alooche.com
ADMIN_URL=https://alooche.com/admin
API_PORT=4000
WEB_PORT=5173
ADMIN_PORT=3001

# LiveKit (Phase 3)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Domain (production)
DOMAIN=alooche.com
ACME_EMAIL=admin@alooche.com
