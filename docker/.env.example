# Database
POSTGRES_USER=agahiram
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agahiram
DATABASE_URL=postgresql://agahiram:change_me_in_production@localhost:5432/agahiram?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# MeiliSearch
MEILI_MASTER_KEY=change_me_in_production
MEILI_HOST=http://localhost:7700

# JWT
JWT_SECRET=change_me_to_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string

# Kavenegar SMS
KAVENEGAR_API_KEY=your_kavenegar_api_key
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_DEV_MODE=true

# ArvanCloud Object Storage (S3-compatible)
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=agahiram
S3_REGION=ir-thr-at1
S3_PUBLIC_URL=https://agahiram.s3.ir-thr-at1.arvanstorage.ir

# ZarinPal
ZARINPAL_MERCHANT_ID=your_merchant_id
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:3000/payment/callback

# Neshan Maps
NESHAN_API_KEY=your_neshan_api_key

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001

# LiveKit (Phase 3)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Domain (production)
DOMAIN=agahiram.ir
ACME_EMAIL=admin@agahiram.ir
