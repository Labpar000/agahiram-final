FROM node:22-alpine AS base
RUN apk add --no-cache libc6-compat \
  && npm install -g pnpm@9.15.0
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* .npmrc turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/config/package.json ./packages/config/
COPY packages/shared/package.json ./packages/shared/
COPY packages/ui/package.json ./packages/ui/
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --filter @agahiram/web... --frozen-lockfile --ignore-scripts

FROM base AS build
ARG NEXT_PUBLIC_API_URL=/api/v1
ARG NEXT_PUBLIC_WS_URL=
ARG NEXT_PUBLIC_APP_URL=/
ARG NEXT_PUBLIC_SOCKET_URL=
ARG NEXT_PUBLIC_MAPIR_API_KEY=
# `next build` bakes the result of `rewrites()` into routes-manifest.json,
# and that result is what `next start` actually serves — runtime changes to
# this env var do NOT re-route requests. So we set it at build time too,
# defaulting to the docker service hostname used in docker-compose.prod.yml.
ARG API_UPSTREAM_URL=http://api:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL \
    NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL \
    NEXT_PUBLIC_SOCKET_URL=$NEXT_PUBLIC_SOCKET_URL \
    NEXT_PUBLIC_MAPIR_API_KEY=$NEXT_PUBLIC_MAPIR_API_KEY \
    API_UPSTREAM_URL=$API_UPSTREAM_URL
COPY --from=deps /app/node_modules ./node_modules
COPY package.json pnpm-workspace.yaml turbo.json ./
COPY apps/web ./apps/web
COPY packages/config ./packages/config
COPY packages/shared ./packages/shared
COPY packages/ui ./packages/ui
RUN pnpm --filter @agahiram/shared build
RUN --mount=type=cache,target=/app/apps/web/.next/cache pnpm --filter @agahiram/web build

FROM base AS runner
ENV NODE_ENV=production
ENV PATH=/app/node_modules/.bin:$PATH
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/packages/shared ./packages/shared
COPY --from=build /app/apps/web/.next ./apps/web/.next
COPY --from=build /app/apps/web/public ./apps/web/public
# The Next.js image optimiser re-reads the `images` config from this file at
# server startup. Without it, runtime falls back to default deviceSizes /
# imageSizes and rejects the custom widths we generate in srcsets (200, 360,
# 414, 768), which surfaces in the browser as 400 on /_next/image requests.
COPY --from=build /app/apps/web/next.config.mjs ./apps/web/
COPY --from=build /app/apps/web/package.json ./apps/web/
COPY --from=build /app/pnpm-workspace.yaml ./
COPY --from=build /app/package.json ./
EXPOSE 5173
WORKDIR /app/apps/web
CMD ["node", "/app/node_modules/next/dist/bin/next", "start", "--port", "5173"]
