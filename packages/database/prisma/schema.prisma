generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
  moderator
}

enum PostStatus {
  draft
  pendingReview
  approved
  rejected
  sold
  expired
  deleted
}

enum PostType {
  post
  reel
}

enum PriceType {
  fixed
  negotiable
  free
  callForPrice
}

enum MediaType {
  image
  video
}

enum AttributeType {
  text
  number
  select
  bool
}

enum NotificationType {
  like
  comment
  follow
  message
  adApproved
  adRejected
  adRemoved
  boostExpiring
  priceDropOnSaved
  storyMention
  walletCredit
  walletDebit
  broadcast
  systemAnnouncement
  incomingCall
  missedCall
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum PaymentPurpose {
  boost
  businessAccount
  walletTopup
}

enum MessageType {
  text
  image
  voice
  post
  call_event
}

enum CallStatus {
  ringing
  accepted
  active
  ended
  missed
  rejected
  busy
  failed
}

enum CallType {
  video
  audio
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum BidType {
  CPM
  CPC
}

enum AdStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  PAUSED
  COMPLETED
}

enum AdSlot {
  STORY
  EXPLORE_FEED
  BANNER
}

enum ContactPreference {
  BOTH
  CALL_ONLY
  MESSAGE_ONLY
}

enum LiveStreamStatus {
  scheduled
  live
  ended
}

enum StoryAudience {
  PUBLIC
  CLOSE_FRIENDS
}

enum StoryAllowReplies {
  EVERYONE
  FOLLOWERS
  FOLLOWING
  OFF
}

enum StoryNavigationType {
  FORWARD
  BACK
  EXIT
  NEXT_ACCOUNT
}

enum StoryStickerType {
  POLL
  QUIZ
  QUESTION
  SLIDER
  COUNTDOWN
  LINK
  MENTION
  HASHTAG
  LOCATION
  NOTIFY
  PRODUCT
  GIF
  TIME
  DATE
  WEATHER
}

enum StoryArchiveAudience {
  PUBLIC
  CLOSE_FRIENDS
}

enum ShopType {
  PERSONAL
  ONLINE_STORE
  PHYSICAL_STORE
  BRAND
}

enum TrustTier {
  UNVERIFIED
  BASIC
  STANDARD
  VERIFIED
  TRUSTED
  PREMIUM
}

enum VerificationType {
  PHONE
  NATIONAL_ID
  BUSINESS_LICENSE
  COMPANY_REG
  ENAMAD
  ADDRESS
  BANK_ACCOUNT
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum BadgeType {
  PHONE_VERIFIED
  IDENTITY_VERIFIED
  BUSINESS_VERIFIED
  ENAMAD_HOLDER
  TOP_SELLER
  FAST_RESPONDER
  TRUSTED_SHOP
}

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  name          String?
  username      String?  @unique
  bio           String?
  avatar        String?
  website       String?
  isVerified    Boolean  @default(false)
  isBusiness    Boolean  @default(false)
  isBanned      Boolean  @default(false)
  isPrivate     Boolean  @default(false)
  karma         Int      @default(0)
  role          UserRole @default(user)
  defaultCityId String?
  walletBalance BigInt   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  defaultCity     City?          @relation(fields: [defaultCityId], references: [id])
  posts           Post[]
  likes           Like[]
  comments        Comment[]
  commentLikes    CommentLike[]
  savedPosts      SavedPost[]
  followers       Follow[]       @relation("Following")
  following       Follow[]       @relation("Follower")
  stories                 Story[]
  storyArchives           StoryArchive[]
  highlights              Highlight[]
  storyViews              StoryView[]
  storyReactions          StoryReaction[]
  storyComments           StoryComment[]
  storyStickerResponses   StoryStickerResponse[]
  closeFriends            CloseFriend[]            @relation("CloseFriendOwner")
  closeFriendOf           CloseFriend[]            @relation("CloseFriendMember")
  storyHiddenFrom         StoryHiddenFrom[]        @relation("StoryHiddenOwner")
  hiddenFromStories       StoryHiddenFrom[]        @relation("StoryHiddenTarget")
  storyMutes              StoryMute[]              @relation("StoryMuteOwner")
  mutedStoryUsers         StoryMute[]              @relation("StoryMuteTarget")
  storySessions           StoryPublishSession[]
  storyNotifySubscriptions StoryNotifySubscription[] @relation("StoryNotifySubscriber")
  storyNotifyProviders    StoryNotifySubscription[] @relation("StoryNotifyProvider")
  storyNavigationEvents   StoryNavigationEvent[]
  storyArchiveEnabled     Boolean                  @default(true)
  defaultStoryAllowReplies StoryAllowReplies       @default(EVERYONE)
  postViews       PostView[]
  notifications   Notification[]
  notificationPref NotificationPreference?
  sentMessages    Message[]      @relation("Sender")
  conversations   ConversationParticipant[]
  reports         Report[]
  payments        Payment[]
  payouts         Payout[]
  liveStreams     LiveStream[]
  searchAlerts    SearchAlert[]
  collections     Collection[]
  blocksMade      Block[]        @relation("Blocker")
  blocksReceived  Block[]        @relation("Blocked")
  pushSubscriptions PushSubscription[]
  callsInitiated    Call[] @relation("CallInitiator")
  callsReceived     Call[] @relation("CallCallee")
  followRequestsSent     FollowRequest[] @relation("FollowRequests")
  followRequestsReceived FollowRequest[] @relation("FollowRequestTargets")
  businessExpiresAt DateTime?
  shop              Shop?
  adCampaigns       AdCampaign[]
  approvedAds       Ad[]          @relation("AdApprovals")
  reviewedAds       Ad[]          @relation("AdReviews")

  @@index([username])
  @@index([phone])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
}

model Category {
  id       String  @id @default(uuid())
  parentId String?
  name     String
  slug     String  @unique
  icon     String?
  order    Int     @default(0)

  parent     Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]          @relation("CategoryTree")
  attributes CategoryAttribute[]
  posts      Post[]

  @@index([parentId])
  @@index([slug])
}

model CategoryAttribute {
  id         String        @id @default(uuid())
  categoryId String
  key        String
  label      String
  type       AttributeType
  options    String[]      @default([])
  required   Boolean       @default(false)
  order      Int           @default(0)

  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  postAttributes PostAttribute[]

  @@unique([categoryId, key])
}

model Province {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  cities City[]
}

model City {
  id         String @id @default(uuid())
  provinceId String
  name       String
  slug       String @unique
  lat        Float?
  lng        Float?

  province      Province       @relation(fields: [provinceId], references: [id])
  neighborhoods Neighborhood[]
  posts         Post[]
  users         User[]
  searchAlerts  SearchAlert[]
  stories       Story[]
  shops         Shop[]

  @@index([provinceId])
}

model Neighborhood {
  id     String @id @default(uuid())
  cityId String
  name   String
  slug   String

  city  City   @relation(fields: [cityId], references: [id])
  posts Post[]

  @@unique([cityId, slug])
}

model Post {
  id                String     @id @default(uuid())
  userId            String
  categoryId        String
  title             String
  description       String?
  price             BigInt?
  priceType         PriceType  @default(fixed)
  currency          String     @default("IRT")
  cityId            String?
  neighborhoodId    String?
  lat               Float?
  lng               Float?
  hideExactLocation Boolean    @default(false)
  status            PostStatus @default(pendingReview)
  type              PostType   @default(post)
  isPromoted        Boolean    @default(false)
  boostExpiresAt    DateTime?
  viewCount         Int        @default(0)
  shareCount        Int        @default(0)
  qualityScore      Int        @default(0)
  commentsEnabled   Boolean    @default(true)
  expiresAt         DateTime?
  rejectionReason   String?
  deletionReason    String?
  contactPreference ContactPreference @default(BOTH)
  /// PostgreSQL tsvector maintained by DB trigger for robust fallback search.
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user         User            @relation(fields: [userId], references: [id])
  category     Category        @relation(fields: [categoryId], references: [id])
  city         City?           @relation(fields: [cityId], references: [id])
  neighborhood Neighborhood?   @relation(fields: [neighborhoodId], references: [id])
  media        PostMedia[]
  attributes   PostAttribute[]
  likes        Like[]
  comments     Comment[]
  saves        SavedPost[]
  stories      Story[]
  reports      Report[]
  messages     Message[]
  payments     Payment[]
  views        PostView[]

  @@index([userId])
  @@index([categoryId])
  @@index([cityId])
  @@index([status, createdAt])
  @@index([isPromoted, boostExpiresAt])
  @@index([type, status])
  @@index([searchVector], type: Gin)
}

model PostMedia {
  id           String    @id @default(uuid())
  postId       String
  url          String
  thumbnailUrl String?
  type         MediaType
  order        Int       @default(0)
  width        Int?
  height       Int?
  duration     Int?
  hlsUrl       String?
  isThumbnail  Boolean   @default(false)
  createdAt    DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostAttribute {
  id          String @id @default(uuid())
  postId      String
  attributeId String
  value       String

  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  attribute CategoryAttribute @relation(fields: [attributeId], references: [id])

  @@unique([postId, attributeId])
}

model StoryPublishSession {
  id          String    @id @default(uuid())
  userId      String
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories Story[]

  @@index([userId, scheduledAt])
}

model Story {
  id           String            @id @default(uuid())
  userId       String
  mediaUrl     String
  mediaKey     String?
  type         MediaType
  expiresAt    DateTime
  linkedPostId String?
  overlayJson  Json?
  durationMs   Int?
  audience     StoryAudience     @default(PUBLIC)
  allowReplies StoryAllowReplies @default(EVERYONE)
  sessionId    String?
  sequenceIndex Int              @default(0)
  altText      String?
  hashtag      String?
  cityId       String?
  hlsUrl       String?
  thumbnailUrl   String?
  publishAt      DateTime           @default(now())
  searchableText String?
  createdAt      DateTime           @default(now())

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedPost Post?                @relation(fields: [linkedPostId], references: [id])
  session    StoryPublishSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  city       City?                @relation(fields: [cityId], references: [id])
  views      StoryView[]
  reactions  StoryReaction[]
  stickers           StorySticker[]
  comments           StoryComment[]
  music              StoryMusic?
  highlights         HighlightStory[]
  navigationEvents   StoryNavigationEvent[]

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([sessionId])
  @@index([hashtag])
  @@index([cityId])
  @@index([publishAt])
  @@index([searchableText])
}

model StoryArchive {
  id              String               @id @default(uuid())
  userId          String
  mediaUrl        String
  mediaKey        String?
  type            MediaType
  overlayJson     Json?
  durationMs      Int?
  linkedPostId    String?
  originalStoryId String?
  sourceAudience  StoryArchiveAudience @default(PUBLIC)
  altText         String?
  hashtag         String?
  cityId          String?
  hlsUrl          String?
  thumbnailUrl    String?
  archivedAt      DateTime             @default(now())
  createdAt       DateTime

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights HighlightStory[]

  @@index([userId, archivedAt])
  @@index([hashtag])
}

model StoryReaction {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId, emoji])
  @@index([storyId])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())
  replayCount Int   @default(0)

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
}

model StoryNavigationEvent {
  id        String              @id @default(uuid())
  storyId   String
  userId    String
  type      StoryNavigationType
  createdAt DateTime            @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, type])
  @@index([userId, storyId])
}

model StorySticker {
  id        String           @id @default(uuid())
  storyId   String
  type      StoryStickerType
  payload   Json
  x         Float            @default(0.5)
  y         Float            @default(0.5)
  scale     Float            @default(1)
  rotation  Float            @default(0)
  createdAt DateTime         @default(now())

  story     Story                  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  responses StoryStickerResponse[]

  @@index([storyId])
}

model StoryStickerResponse {
  id        String   @id @default(uuid())
  stickerId String
  userId    String
  value     Json
  createdAt DateTime @default(now())

  sticker StorySticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stickerId, userId])
  @@index([stickerId])
  @@index([userId])
}

model StoryComment {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
}

model CloseFriend {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  owner  User @relation("CloseFriendOwner", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("CloseFriendMember", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
}

model StoryHiddenFrom {
  id           String   @id @default(uuid())
  userId       String
  hiddenUserId String
  createdAt    DateTime @default(now())

  owner  User @relation("StoryHiddenOwner", fields: [userId], references: [id], onDelete: Cascade)
  hidden User @relation("StoryHiddenTarget", fields: [hiddenUserId], references: [id], onDelete: Cascade)

  @@unique([userId, hiddenUserId])
}

model StoryMute {
  id            String   @id @default(uuid())
  userId        String
  mutedUserId   String
  createdAt     DateTime @default(now())

  owner User @relation("StoryMuteOwner", fields: [userId], references: [id], onDelete: Cascade)
  muted User @relation("StoryMuteTarget", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedUserId])
}

model StoryNotifySubscription {
  id             String   @id @default(uuid())
  subscriberId   String
  providerUserId String
  createdAt      DateTime @default(now())

  subscriber User @relation("StoryNotifySubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  provider   User @relation("StoryNotifyProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, providerUserId])
}

model StoryLinkClick {
  id        String   @id @default(uuid())
  storyId   String
  userId    String?
  stickerId String?
  url       String
  createdAt DateTime @default(now())

  @@index([storyId])
}

model StoryMusic {
  id          String @id @default(uuid())
  storyId     String @unique
  trackId     String
  startMs     Int    @default(0)
  displayMode String @default("minimal")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([trackId])
}

model Highlight {
  id          String   @id @default(uuid())
  userId      String
  title       String
  coverUrl    String?
  pinnedOrder Int?
  createdAt   DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories HighlightStory[]

  @@index([userId, pinnedOrder])
}

model HighlightStory {
  id              String  @id @default(uuid())
  highlightId     String
  storyId         String?
  storyArchiveId  String?
  order           Int     @default(0)

  highlight    Highlight     @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  story        Story?        @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyArchive StoryArchive? @relation(fields: [storyArchiveId], references: [id], onDelete: Cascade)

  @@index([highlightId, order])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  parentId  String?
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SavedPost {
  id           String   @id @default(uuid())
  userId       String
  postId       String
  collectionId String?
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id])

  @@unique([userId, postId])
  @@index([userId])
}

model Collection {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  saves SavedPost[]
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FollowRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  requester User @relation("FollowRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FollowRequestTargets", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  calls        Call[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(text)
  postId         String?
  storyId        String?
  metadata       Json?
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("Sender", fields: [senderId], references: [id])
  post         Post?        @relation(fields: [postId], references: [id])

  @@index([conversationId, createdAt])
}

model Call {
  id             String     @id @default(uuid())
  conversationId String
  initiatorId    String
  calleeId       String
  type           CallType   @default(video)
  status         CallStatus @default(ringing)
  roomName       String     @unique
  startedAt      DateTime?
  answeredAt     DateTime?
  endedAt        DateTime?
  endReason      String?
  durationSec    Int?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator      User         @relation("CallInitiator", fields: [initiatorId], references: [id])
  callee         User         @relation("CallCallee", fields: [calleeId], references: [id])

  @@index([conversationId, createdAt])
  @@index([calleeId, status])
  @@index([initiatorId, status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum ReportTargetType {
  post
  story
  user
  comment
  ad
}

model Report {
  id         String           @id @default(uuid())
  reporterId String
  postId     String?
  targetType ReportTargetType
  targetId   String
  reason     String
  details    String?
  status     String           @default("pending")
  createdAt  DateTime         @default(now())

  reporter User  @relation(fields: [reporterId], references: [id])
  post     Post? @relation(fields: [postId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model BoostPlan {
  id            String  @id @default(uuid())
  name          String
  durationHours Int
  price         BigInt
  description   String?
  isActive      Boolean @default(true)

  payments Payment[]
}

model Payment {
  id        String         @id @default(uuid())
  userId    String
  postId    String?
  planId    String?
  amount    BigInt
  purpose   PaymentPurpose
  gateway   String         @default("zarinpal")
  authority String?
  refId     String?
  status    PaymentStatus  @default(pending)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User       @relation(fields: [userId], references: [id])
  post Post?      @relation(fields: [postId], references: [id])
  plan BoostPlan? @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([authority])
  @@index([status])
}

model SearchAlert {
  id        String   @id @default(uuid())
  userId    String
  query     String?
  filters   Json
  cityId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City? @relation(fields: [cityId], references: [id])
}

model LiveStream {
  id           String           @id @default(uuid())
  userId       String
  title        String
  status       LiveStreamStatus @default(scheduled)
  roomName     String           @unique
  viewerCount  Int              @default(0)
  linkedPostId String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// Single-row-per-key, JSON-valued platform-wide settings (maintenance, registration,
/// site name, etc). Read frequently — every authenticated request may touch a subset.
model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/// Append-only audit trail of every privileged mutation in the admin panel.
/// `target` is `<kind>:<id>` (e.g. `post:abc`, `user:def`). `payload` captures
/// the request body and any rejection/ban reasons so investigators can reconstruct
/// what actually happened without trawling logs.
model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actorRole String
  action    String
  target    String?
  payload   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([target])
  @@index([action, createdAt])
  @@index([createdAt])
}

/// Per-post view event used for analytics (unique vs repeat, time-of-day, last
/// 7 days) and the "already viewed" indicator. `userId` is null for anonymous
/// views; `viewerHash` lets us dedupe per visitor without exposing IPs.
model PostView {
  id         String   @id @default(uuid())
  postId     String
  userId     String?
  viewerHash String?
  viewedAt   DateTime @default(now())

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([postId, viewedAt])
  @@index([userId, viewedAt])
}

/// One user blocking another. Used to hide content / disallow messages.
model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Shop {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopType     ShopType
  slug         String    @unique
  name         String
  description  String?
  logo         String?
  coverImage   String?
  category     String?
  website      String?
  contactPhone String?
  address      String?
  cityId       String?
  city         City?     @relation(fields: [cityId], references: [id])
  workingHours Json?
  trustScore   Int       @default(0)
  trustTier    TrustTier @default(UNVERIFIED)
  isActive     Boolean   @default(true)
  isFeatured   Boolean   @default(false)
  verifications VerificationRequest[]
  badges        ShopBadge[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([slug])
  @@index([userId])
  @@index([trustTier])
}

model VerificationRequest {
  id           String             @id @default(uuid())
  shopId       String
  shop         Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type         VerificationType
  status       VerificationStatus @default(PENDING)
  documents    String[]
  adminNote    String?
  reviewedById String?
  reviewedAt   DateTime?
  scoreGranted Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([shopId])
  @@index([status, createdAt])
  @@index([type, status])
}

model ShopBadge {
  id        String    @id @default(uuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type      BadgeType
  grantedAt DateTime  @default(now())

  @@unique([shopId, type])
  @@index([shopId])
}

/// Per-user notification delivery preferences. `null` row means defaults (all on).
model NotificationPreference {
  userId         String   @id
  likesPush      Boolean  @default(true)
  commentsPush   Boolean  @default(true)
  followsPush    Boolean  @default(true)
  messagesPush   Boolean  @default(true)
  likesEmail     Boolean  @default(false)
  commentsEmail  Boolean  @default(false)
  followsEmail   Boolean  @default(false)
  messagesEmail  Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PayoutStatus {
  pending
  approved
  rejected
  paid
}

/// User-initiated wallet withdrawal request. Admin approves -> balance is
/// debited atomically and status moves through approved -> paid (manual bank
/// transfer outside the system).
model Payout {
  id          String       @id @default(uuid())
  userId      String
  amount      BigInt
  cardNumber  String?
  iban        String?
  status      PayoutStatus @default(pending)
  rejectReason String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// Advertising System
// ═══════════════════════════════════════════════════════════════

model AdCampaign {
  id            String           @id @default(uuid())
  name          String
  advertiserId  String
  advertiser    User             @relation(fields: [advertiserId], references: [id])
  status        AdCampaignStatus @default(DRAFT)
  budget        BigInt
  totalSpent    BigInt           @default(0)
  dailyBudget   BigInt?
  bidType       BidType          @default(CPM)
  bidAmount     BigInt
  startDate     DateTime
  endDate       DateTime?
  pauseReason   String?
  targeting     Json?
  ads           Ad[]
  payments      AdPayment[]
  dailySpends   AdDailySpend[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([advertiserId])
  @@index([status])
}

model AdDailySpend {
  id         String     @id @default(uuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date       DateTime   @db.Date
  amount     BigInt     @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([campaignId, date])
  @@index([campaignId])
}

model Ad {
  id            String    @id @default(uuid())
  campaignId    String
  campaign      AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title         String?
  description   String?
  mediaUrl      String
  redirectUrl   String?
  slot          AdSlot
  status        AdStatus  @default(PENDING_REVIEW)
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  ctr           Float     @default(0)
  spent         BigInt    @default(0)
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("AdApprovals", fields: [approvedById], references: [id])
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?     @relation("AdReviews", fields: [reviewedById], references: [id])
  adminNote     String?
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  impressionsRel AdImpression[]
  clicksRel      AdClick[]

  @@index([campaignId])
  @@index([status])
  @@index([slot])
}

model AdImpression {
  id        String   @id @default(uuid())
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  userId    String?
  sessionId String?
  source    String   @default("explore")
  createdAt DateTime @default(now())

  @@index([adId])
  @@index([createdAt])
}

model AdClick {
  id         String   @id @default(uuid())
  adId       String
  ad         Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  userId     String?
  sessionId  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adId])
  @@index([createdAt])
}

model AdPayment {
  id         String     @id @default(uuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adId       String?
  amount     BigInt
  refId      String?
  status     String     @default("DEBITED")
  note       String?
  createdAt  DateTime   @default(now())

  @@index([campaignId])
  @@index([adId])
}
