{
  "name": "@agahiram/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./components/ig/*": {
      "types": "./src/components/ig/*.tsx",
      "import": "./src/components/ig/*.tsx",
      "default": "./src/components/ig/*.tsx"
    },
    "./components/ig-icons": {
      "types": "./src/components/ig-icons.tsx",
      "import": "./src/components/ig-icons.tsx",
      "default": "./src/components/ig-icons.tsx"
    },
    "./components/ig-icons/types": {
      "types": "./src/components/ig-icons/types.ts",
      "import": "./src/components/ig-icons/types.ts",
      "default": "./src/components/ig-icons/types.ts"
    },
    "./components/ig-icons/shared": {
      "types": "./src/components/ig-icons/shared.ts",
      "import": "./src/components/ig-icons/shared.ts",
      "default": "./src/components/ig-icons/shared.ts"
    },
    "./components/ig-icons/*": {
      "types": "./src/components/ig-icons/*.tsx",
      "import": "./src/components/ig-icons/*.tsx",
      "default": "./src/components/ig-icons/*.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "import": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@agahiram/shared": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.511.0",
    "next-themes": "^0.4.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@agahiram/config": "workspace:*",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
