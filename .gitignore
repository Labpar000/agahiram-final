# =====================================================
dist/
**/dist/
build/
**/build/
out/
**/out/
.next/
**/.next/
.nuxt/
.svelte-kit/
.vercel/
.turbo/
**/.turbo/
.cache/
!.cache/.gitkeep
*.tsbuildinfo
**/*.tsbuildinfo

# =====================================================
# Environment & secrets - NEVER COMMIT
# =====================================================
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.*.example
docker/.env
docker/.env.*
