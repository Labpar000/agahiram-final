{
  "name": "agahiram",
  "version": "0.1.0",
  "private": true,
  "description": "آگهی‌گرام - Instagram × Divar classified ads platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:eslint": "eslint \"packages/shared/src/**/*.ts\" \"apps/api/src/**/*.ts\" --max-warnings 0",
    "typecheck": "turbo run lint",
    "test": "pnpm db:generate && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "pnpm --filter @agahiram/api test",
    "test:e2e": "pnpm --filter @agahiram/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "db:generate": "pnpm --filter @agahiram/database generate",
    "db:migrate": "pnpm --filter @agahiram/database migrate:dev",
    "db:seed": "pnpm --filter @agahiram/database seed",
    "db:studio": "pnpm --filter @agahiram/database studio",
    "clean": "turbo run clean && rimraf node_modules",
    "qa:preflight": "bash scripts/qa-preflight.sh",
    "media:range": "bash scripts/check-media-range.sh",
    "figma:sync": "npx tsx scripts/figma-sync-status.ts"
  },
  "devDependencies": {
    "@agahiram/config": "workspace:*",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
