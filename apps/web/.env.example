# Same-origin proxy via Next rewrites (recommended). Omit to default to /api/v1 in browser.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Map.ir (web tile + style.json). Use a key whitelisted to your domain in production.
NEXT_PUBLIC_MAPIR_API_KEY=
