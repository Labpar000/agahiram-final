# Copy to apps/api/.env for local development (see also docker/.env.example)

PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://agahiram:change_me_in_production@localhost:5432/agahiram?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# MeiliSearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=agahiram_meili_dev_key

# Run search-index worker inside the API process (set false when using media-processor worker)
RUN_IN_PROCESS_SEARCH_WORKER=true

# JWT & cookies
JWT_SECRET=change_me_to_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
COOKIE_SECRET=change_me_to_another_random_64_char_string
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# CORS — comma-separated origins; defaults include localhost:5173 (Vite web dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:3001
# Docker preview (Caddy on :8095): add http://localhost:8095 to CORS_ORIGIN and set
# FRONTEND_URL=http://localhost:8095, NEXT_PUBLIC_API_URL=http://localhost:8095/api/v1

# Admin allowlist (comma-separated phone numbers)
ADMIN_PHONES=09120000000,09127477990,09132609737

# SMS (dev mode prints OTP to console)
SMS_PROVIDER=dev
KAVENEGAR_DEV_MODE=true

# MinIO (local docker — `cd docker && docker compose up -d minio createbuckets`)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
# Browser uploads go through the API proxy (PUT /api/v1/media/upload), not presigned MinIO URLs.
# MINIO_PUBLIC_* is only used for legacy signed reads; local dev can leave these as-is.
MINIO_PUBLIC_HOST=localhost
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false
MINIO_PUBLIC_PATH_PREFIX=
MINIO_BUCKET=agahiram
MINIO_ACCESS_KEY=agahiram
MINIO_SECRET_KEY=change_me_in_production

# ZarinPal sandbox
ZARINPAL_MERCHANT_ID=your_merchant_id
ZARINPAL_SANDBOX=true

# Map.ir (geocoding + search)
MAPIR_API_KEY=your_mapir_api_key

# LiveKit (optional — 1:1 calls)
LIVEKIT_API_KEY=agahiram_lk
LIVEKIT_API_SECRET=generate_with_openssl_rand_hex_32
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_INTERNAL_URL=http://localhost:7880

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@alooche.com
